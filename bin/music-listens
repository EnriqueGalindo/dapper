#!/usr/bin/env python3
"""
music-listens — detect what was played on the DAP by reading the SD card's
per-file last-ACCESS timestamps (no script runs on the player itself).

Premise: exFAT stores a last-accessed time per file. macOS mounts the card
'noatime', so reads on the Mac don't disturb it. IF the Echo Mini's firmware
updates a file's access time when it plays the file, then a file whose atime
advanced since our last snapshot was played on the device.

THIS IS UNPROVEN for the Echo Mini — that's what `snapshot` + `check` test.

Usage:
    music-listens snapshot          # record current access-times as baseline
      ... go play some tracks on the DAP, then reinsert the card ...
    music-listens check             # show files whose atime advanced (= played?)
    music-listens check --commit    # also add those to cumulative counts, re-snapshot
    music-listens top               # cumulative most-played (once proven to work)

Data: ~/.local/share/music-listens/  (baseline.tsv, counts.json)
"""

import argparse
import json
import os
import sys
from datetime import datetime
from pathlib import Path

CARD = Path("/Volumes/MUSIC")
DATA = Path.home() / ".local/share/music-listens"
BASELINE = DATA / "baseline.tsv"
COUNTS = DATA / "counts.json"
AUDIO_EXTS = {".mp3", ".m4a", ".m4b", ".flac", ".aac", ".ogg",
              ".opus", ".wav", ".wma", ".alac", ".aiff", ".aif"}


def walk_atimes(root):
    """Yield (relpath, atime_float) for every audio file under root."""
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [d for d in dirnames if not d.startswith(".")]
        for fn in filenames:
            if Path(fn).suffix.lower() in AUDIO_EXTS:
                p = Path(dirpath) / fn
                try:
                    yield str(p.relative_to(root)), p.stat().st_atime
                except OSError:
                    pass


def require_card():
    if not CARD.is_dir():
        sys.exit(f"error: card not mounted at {CARD}")


def cmd_snapshot(args):
    require_card()
    DATA.mkdir(parents=True, exist_ok=True)
    n = 0
    with BASELINE.open("w") as fh:
        for rel, at in walk_atimes(CARD):
            fh.write(f"{at:.0f}\t{rel}\n")
            n += 1
    print(f"Snapshot saved: {n} files at {datetime.now():%Y-%m-%d %H:%M:%S}")
    print("Now play some tracks on the DAP, reinsert the card, and run: "
          "music-listens check")


def load_baseline():
    if not BASELINE.exists():
        sys.exit("No baseline. Run:  music-listens snapshot")
    base = {}
    for line in BASELINE.read_text().splitlines():
        if not line.strip():
            continue
        at, rel = line.split("\t", 1)
        base[rel] = float(at)
    return base


def cmd_check(args):
    require_card()
    base = load_baseline()
    played = []
    for rel, at in walk_atimes(CARD):
        prev = base.get(rel)
        # advanced access time (allow 2s exFAT granularity slack) = a read since snapshot
        if prev is not None and at - prev > 2:
            played.append((rel, prev, at))
    played.sort(key=lambda x: x[2])

    if not played:
        print("No files show an advanced access-time since the snapshot.")
        print("Either nothing was played, or the Echo Mini does NOT update "
              "access times on playback (then this approach can't work).")
        return

    print(f"{len(played)} file(s) accessed since snapshot "
          f"(candidate listens):\n")
    for rel, prev, at in played:
        when = datetime.fromtimestamp(at).strftime("%Y-%m-%d %H:%M:%S")
        print(f"  {when}  {rel}")

    if args.commit:
        counts = json.loads(COUNTS.read_text()) if COUNTS.exists() else {}
        for rel, _p, _a in played:
            counts[rel] = counts.get(rel, 0) + 1
        DATA.mkdir(parents=True, exist_ok=True)
        COUNTS.write_text(json.dumps(counts, indent=0))
        cmd_snapshot(args)  # re-baseline so next check is incremental
        print(f"\nCommitted {len(played)} play(s) to cumulative counts.")


def cmd_top(args):
    if not COUNTS.exists():
        sys.exit("No counts yet. Use `music-listens check --commit` first.")
    counts = json.loads(COUNTS.read_text())
    rows = sorted(counts.items(), key=lambda x: -x[1])[:args.limit]
    print("Most-played (by cumulative access-time bumps):")
    for rel, c in rows:
        print(f"  {c:>4}  {rel}")


def main():
    ap = argparse.ArgumentParser(
        description="Track DAP listens via SD-card file access-times.",
        formatter_class=argparse.RawDescriptionHelpFormatter, epilog=__doc__)
    sub = ap.add_subparsers(dest="cmd", required=True)
    sub.add_parser("snapshot", help="record current access-times as baseline")
    c = sub.add_parser("check", help="show files accessed since the snapshot")
    c.add_argument("--commit", action="store_true",
                   help="add detected plays to cumulative counts and re-snapshot")
    t = sub.add_parser("top", help="cumulative most-played")
    t.add_argument("--limit", type=int, default=20)
    args = ap.parse_args()

    {"snapshot": cmd_snapshot, "check": cmd_check, "top": cmd_top}[args.cmd](args)


if __name__ == "__main__":
    main()
